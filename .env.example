# Environment Variables for Yashoda Properties

# Database Configuration
DATABASE_URL=sqlite:///./app.db

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
NODE_ENV=production
PYTHONUNBUFFERED=1

# Frontend Configuration
VITE_API_URL=
FRONTEND_DIST_PATH=/app/frontend/dist

# WhatsApp API (Optional - for production WhatsApp integration)
WHATSAPP_API_URL=https://api.whatsapp.com/v1
WHATSAPP_API_TOKEN=your-whatsapp-api-token

# Optional: PostgreSQL Database (uncomment and configure if using PostgreSQL)
# DATABASE_URL=postgresql://username:password@host:port/database_name

# Optional: Redis for caching (uncomment if using Redis)
# REDIS_URL=redis://localhost:6379

# Optional: Email configuration (uncomment if using email features)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password